DATABASE_URL="file:./dev.db"
NEXTAUTH_SECRET="replace-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_NAME="Aurum Blog"

# Leave blank to disable — see README "Integrations" section
NEXT_PUBLIC_GA_ID=""
NEXT_PUBLIC_ADSENSE_CLIENT=""
NEXT_PUBLIC_GSC_VERIFICATION=""

# Used once by `npm run db:seed` to create the first Admin account
SEED_ADMIN_EMAIL="admin@aurum.blog"
SEED_ADMIN_PASSWORD="ChangeMe123!"

# Protects /api/cron/publish-scheduled from being triggered by randoms
CRON_SECRET="replace-with-a-random-string"
