// ============================================================
// Aurum Blog — Prisma Schema
// Swap provider to "postgresql" + set DATABASE_URL for production.
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite" // change to "postgresql" for production
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  EDITOR
}

enum PostStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
  TRASHED
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  passwordHash  String
  role          Role      @default(EDITOR)
  avatarUrl     String?
  bio           String?
  twitterHandle String?
  websiteUrl    String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  posts         Post[]
  comments      Comment[]
}

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  posts       Post[]
  createdAt   DateTime @default(now())
}

model Tag {
  id    String @id @default(cuid())
  name  String @unique
  slug  String @unique
  posts Post[]
}

model Media {
  id        String   @id @default(cuid())
  url       String
  filename  String
  altText   String?
  width     Int?
  height    Int?
  sizeBytes Int?
  mimeType  String?
  uploadedBy String?
  createdAt DateTime @default(now())
}

model Post {
  id              String     @id @default(cuid())
  title           String
  slug            String     @unique
  excerpt         String?
  contentHtml     String     // rich text editor output
  contentJson     String?    // raw TipTap JSON for re-editing
  coverImageUrl   String?
  status          PostStatus @default(DRAFT)
  isFeatured      Boolean    @default(false)
  isSticky        Boolean    @default(false)
  isTrending      Boolean    @default(false)
  isSponsored     Boolean    @default(false)
  sponsorName     String?
  readingTimeMins Int        @default(1)
  viewCount       Int        @default(0)

  publishedAt     DateTime?
  scheduledAt     DateTime?
  deletedAt       DateTime?

  // SEO
  seoTitle        String?
  metaDescription String?
  metaKeywords    String?
  canonicalUrl    String?
  ogImageUrl      String?
  noIndex         Boolean    @default(false)

  authorId        String
  author          User       @relation(fields: [authorId], references: [id])
  categoryId      String?
  category        Category?  @relation(fields: [categoryId], references: [id])
  tags            Tag[]
  comments        Comment[]
  affiliateLinks  AffiliateLink[]

  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@index([status, publishedAt])
  @@index([isFeatured])
  @@index([isTrending])
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  approved  Boolean  @default(false)
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId  String?
  author    User?    @relation(fields: [authorId], references: [id])
  guestName String?
  guestEmail String?
  parentId  String?
  parent    Comment? @relation("Replies", fields: [parentId], references: [id])
  replies   Comment[] @relation("Replies")
  createdAt DateTime @default(now())
}

model AffiliateLink {
  id        String   @id @default(cuid())
  label     String
  targetUrl String
  clicks    Int      @default(0)
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
}

model NewsletterSubscriber {
  id          String   @id @default(cuid())
  email       String   @unique
  confirmed   Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model BannerAd {
  id        String   @id @default(cuid())
  name      String
  placement String   // "home-top", "sidebar", "in-article", etc.
  imageUrl  String
  linkUrl   String
  active    Boolean  @default(true)
}

model SiteSetting {
  id    String @id @default("singleton")
  key   String @unique
  value String
}
